<!DOCTYPE html><html lang="de"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Kollektionserfassung V7</title><style>body{font-family:-apple-system,sans-serif;margin:0;background:#f4f5f7}header{background:#6AA84F;color:#fff;padding:16px;text-align:center;font-size:22px;font-weight:bold}.bar{padding:10px;background:#eef}nav{display:flex;gap:4px;padding:8px}nav button{flex:1;padding:12px}section{display:none;padding:12px}.show{display:block}.card{background:#fff;border-radius:12px;padding:12px;margin-bottom:12px}input,select,textarea,button{width:100%;box-sizing:border-box;padding:10px;margin-top:6px}.green{background:#6AA84F;color:#fff;border:0}.entry{border:1px solid #ddd;border-radius:8px;padding:8px;margin-top:8px}</style></head><body><header>Kollektionserfassung V7</header><div class='bar' id='status'>Aktive Seite: Erfassung</div><nav><button data-page='erf'>Erfassung</button><button data-page='kun'>Kunden</button><button data-page='kol'>Kollektionen</button><button data-page='exp'>Export</button></nav><section id='erf' class='show'><div class='card'><input type='date' id='datum'><select id='kunde'></select><select id='kollektion'></select><input id='preis' placeholder='Preis'><input id='rabatt' value='40' placeholder='Rabatt %'><textarea id='bem'></textarea><button class='green' id='save'>Eintrag übernehmen</button></div><div class='card'><div id='liste'></div></div></section><section id='kun'><div class='card'><input id='newCustomer' placeholder='Neuer Kunde'><button class='green' id='addCustomer'>Kunde hinzufügen</button><div id='customerList'></div></div></section><section id='kol'><div class='card'><input id='newCollection' placeholder='Neue Kollektion'><button class='green' id='addCollection'>Kollektion hinzufügen</button><div id='collectionList'></div></div></section><section id='exp'><div class='card'><button class='green' id='export'>CSV erzeugen</button><textarea id='csv' rows='10'></textarea></div></section><script>const $=id=>document.getElementById(id);let customers=['Möbelhaus Müller','Wohnstudio Hansen','Möbel Kraft','Mömax','XXXLutz','Höffner'];let collections=['Modern Living','Premium Textile','Loft Collection','Nature Line','Classic Home','Urban Design'];let entries=[];$('datum').value=new Date().toISOString().split('T')[0];document.querySelectorAll('nav button').forEach(b=>b.addEventListener('click',function(){document.querySelectorAll('section').forEach(s=>s.classList.remove('show'));let p=this.dataset.page;$(p).classList.add('show');$('status').innerText='Aktive Seite: '+this.innerText;}));function refresh(){ $('kunde').innerHTML=customers.map(v=>'<option>'+v+'</option>').join(''); $('kollektion').innerHTML=collections.map(v=>'<option>'+v+'</option>').join(''); $('customerList').innerHTML=customers.join('<br>'); $('collectionList').innerHTML=collections.join('<br>'); $('liste').innerHTML=entries.map((e,i)=>'<div class="entry">'+e.datum+'<br>'+e.kunde+'<br>'+e.kollektion+'<br>'+e.preis+' €<button onclick="entries.splice('+i+',1);refresh()">Löschen</button></div>').join(''); } $('addCustomer').onclick=()=>{if($('newCustomer').value){customers.push($('newCustomer').value);refresh();}}; $('addCollection').onclick=()=>{if($('newCollection').value){collections.push($('newCollection').value);refresh();}}; $('save').onclick=()=>{entries.push({datum:$('datum').value,kunde:$('kunde').value,kollektion:$('kollektion').value,preis:$('preis').value});refresh();}; $('export').onclick=()=>{$('csv').value=entries.map(e=>e.datum+';'+e.kunde+';'+e.kollektion+';'+e.preis).join('
')}; refresh();</script></body></html>
